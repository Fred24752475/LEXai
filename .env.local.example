# ---- Supabase ----
# From your Supabase project: Settings -> API
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key

# Service role key (server-only, never expose to the browser): Settings -> API
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Direct Postgres connection string for running migrations via `npm run db:push`.
# Settings -> Database -> Connection string -> URI (use the connection pooler URI is fine).
# Example: postgresql://postgres.<ref>:<password>@aws-0-eu-west-1.pooler.supabase.com:5432/postgres
SUPABASE_DB_URL=postgresql://postgres:[password]@db.YOUR_PROJECT_REF.supabase.co:5432/postgres

# ---- Groq (AI inference) ----
# https://console.groq.com/keys
GROQ_API_KEY=gsk_your-groq-api-key
